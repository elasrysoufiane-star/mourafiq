# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer le fichier .env dans git

# ── API Obligatoire ────────────────────────────────────────────────────────────
# Créer sur console.groq.com → API Keys
GROQ_API_KEY=gsk_votre_cle_groq_ici

# ── Mode ──────────────────────────────────────────────────────────────────────
# free  → Groq + edge-tts (défaut, tout gratuit)
# demo  → modifier les providers ci-dessous pour activer les options payantes
DEMO_MODE=free

# ── Providers ─────────────────────────────────────────────────────────────────
AI_PROVIDER=groq          # groq (défaut) | openai (futur)
STT_PROVIDER=groq         # groq (défaut) | openai (futur)
TTS_PROVIDER=edge         # edge (défaut) | gtts | elevenlabs

# ── Clés API payantes (laisser vide si non utilisé) ───────────────────────────

# ElevenLabs — TTS haute qualité multilingue (mode démo)
# Créer sur elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# Voice ID depuis lab.elevenlabs.io/voice-library
# Laisser vide = voix Adam par défaut (supporte l'arabe via multilingual v2)
# Exemple arabophone : Aria = 9BWtsMINqrJLrRacOk9x
ELEVENLABS_VOICE_ID=

# OpenAI — GPT-4o-mini / Whisper (non utilisé par défaut, structure prête)
OPENAI_API_KEY=

# ── Claude (Anthropic) — vision (obligatoire, YOLO retiré) + langage (optionnel) ─
# La description de scène passe TOUJOURS par Claude (pas de fallback local) —
# sans clé, l'assistant dit clairement qu'il ne peut pas voir, jamais de silence.
# OCR_PROVIDER : local/Tesseract (gratuit, défaut) | claude (payant, lecture plus riche).
# AI_PROVIDER (section Providers ci-dessus) = conversation darija (groq/claude).
OCR_PROVIDER=local
# Clé sur console.anthropic.com → API Keys (format sk-ant-...).
ANTHROPIC_API_KEY=
# Modèles. Stratégie MIXTE conseillée : Haiku en continu (pas cher), Sonnet à la demande.
CLAUDE_TEXT_MODEL=claude-haiku-4-5         # conversation darija
CLAUDE_VISION_MODEL=claude-haiku-4-5       # description AUTO continue (pas cher)
CLAUDE_VISION_MODEL_HQ=claude-haiku-4-5    # « شنو قدامي » + OCR à la demande (mettre sonnet)

# ── Description automatique de la scène + OCR (TOUJOURS active, avec ou sans micro) ─
# Toutes les N secondes : capture → description (Claude) + lecture de texte →
# voix, en parallèle de la conversation. Que l'utilisateur parle ou non, la
# scène est décrite et tout texte visible est lu. 0 = désactivé.
# ≈1800 appels Claude/h à 2s pour la scène seule, × 2 si OCR_PROVIDER=claude aussi.
AUTO_DESCRIBE_INTERVAL=2

# Pour activer « FULL CLAUDE » (cerveau 100% Claude, vision + langage) : mettre
#   AI_PROVIDER=claude, OCR_PROVIDER=claude, ANTHROPIC_API_KEY=sk-ant-...,
#   CLAUDE_TEXT_MODEL=claude-sonnet-5, CLAUDE_VISION_MODEL_HQ=claude-sonnet-5
# STT reste Whisper/Groq et TTS reste edge-tts (Claude ne fait pas d'audio).
# Profils eco/mixte/max détaillés : .claude/skills/tune-claude/SKILL.md
