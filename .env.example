# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer le fichier .env dans git

# ── API Obligatoire ────────────────────────────────────────────────────────────
# Créer sur console.groq.com → API Keys
GROQ_API_KEY=gsk_votre_cle_groq_ici

# ── Mode ──────────────────────────────────────────────────────────────────────
# free  → Groq + edge-tts (défaut, tout gratuit)
# demo  → modifier les providers ci-dessous pour activer les options payantes
DEMO_MODE=free

# ── Providers ─────────────────────────────────────────────────────────────────
AI_PROVIDER=groq          # groq (défaut) | openai (futur)
STT_PROVIDER=groq         # groq (défaut) | openai (futur)
TTS_PROVIDER=edge         # edge (défaut) | gtts | elevenlabs

# ── Clés API payantes (laisser vide si non utilisé) ───────────────────────────

# ElevenLabs — TTS haute qualité multilingue (mode démo)
# Créer sur elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# Voice ID depuis lab.elevenlabs.io/voice-library
# Laisser vide = voix Adam par défaut (supporte l'arabe via multilingual v2)
# Exemple arabophone : Aria = 9BWtsMINqrJLrRacOk9x
ELEVENLABS_VOICE_ID=

# OpenAI — GPT-4o-mini / Whisper (non utilisé par défaut, structure prête)
OPENAI_API_KEY=
